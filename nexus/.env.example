# ==============================================================================
# DATABASE - Get your connection strings from Supabase > Settings > Database
# ==============================================================================
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Optional: separate connection for system operations (Stripe webhooks, cron).
# Falls back to DATABASE_URL if not set.
# SYSTEM_DATABASE_URL="postgresql://..."

# ==============================================================================
# CLERK AUTH - Get new keys from Clerk Dashboard > API Keys
# ==============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# Clerk Redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ==============================================================================
# APP URL - Your app's public URL
# ==============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ==============================================================================
# STRIPE BILLING - Get keys from Stripe Dashboard > Developers > API Keys
# ==============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
STRIPE_PRO_YEARLY_PRICE_ID=price_your_yearly_price_id_here

# ==============================================================================
# SUPABASE - Get from Supabase Dashboard > Settings > API
# ==============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key for server-side file uploads (NEVER expose on client side)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==============================================================================
# MONITORING - Optional: Configure after running Sentry wizard
# ==============================================================================
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ==============================================================================
# AI FEATURES - Optional: Powers AI card suggestions, checklists, descriptions
# ==============================================================================
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_api_key_here
# Model to use (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini
# Max AI calls per org per day (default: 50)
# AI_DAILY_LIMIT=50

# ==============================================================================
# GIF API - Optional: For GIF picker in rich text editor
# ==============================================================================
# Choose ONE provider (Giphy recommended - easiest setup):

# Option 1: GIPHY (RECOMMENDED - Free, easy setup, no credit card)
# Get your key at: https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here

# Option 2: Klipy
# Get your key at: https://klipy.com/developers
# KLIPY_API_KEY=your_klipy_api_key_here

# ==============================================================================
# UNSPLASH - Optional: For cover image picker
# ==============================================================================
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_access_key_here
# Server-side only Unsplash key (never exposed to client)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ==============================================================================
# RESEND EMAIL - Get your API key from https://resend.com/api-keys
# ==============================================================================
RESEND_API_KEY=re_your_resend_api_key_here
# Sender address (must be verified in Resend)
EMAIL_FROM=Nexus <notifications@yourdomain.com>

# ==============================================================================
# PUSH NOTIFICATIONS - Optional: Web push via VAPID keys
# Generate keys: npx web-push generate-vapid-keys
# ==============================================================================
# VAPID_PUBLIC_KEY=your_vapid_public_key_here
# VAPID_PRIVATE_KEY=your_vapid_private_key_here
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ==============================================================================
# RATE LIMITING - Optional: Upstash Redis for distributed rate limiting
# Without these, rate limiting falls back to in-memory (single-instance only)
# Get keys at: https://console.upstash.com/
# ==============================================================================
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ==============================================================================
# INTEGRATIONS - Optional: Webhook secrets for third-party integrations
# ==============================================================================
# Slack: https://api.slack.com/apps → Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=your_slack_signing_secret_here
# GitHub: Repository → Settings → Webhooks → Secret
# GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# ==============================================================================
# DATABASE SHARDING (Optional) — Multi-region / HA setup
# ==============================================================================
# Leave these unset to run in single-shard mode (all traffic to DATABASE_URL).
# When set, the shard router (lib/shard-router.ts) distributes org traffic
# across shards using FNV-1a consistent hashing. Each org is deterministically
# assigned to one shard. If that shard fails, traffic routes to the next
# healthy shard automatically (30-second TTL health cache).
#
# IMPORTANT: Changing the shard count remaps ~50% of orgs to different shards.
# Always migrate org data before incrementing the shard count in production.
#
# Monitor shard health: GET /api/health/shards
#   Header: Authorization: Bearer <CRON_SECRET>
#
# Failover test: npm run test:shards
#
# SHARD_0_DATABASE_URL="postgresql://user:pass@shard0.host:6543/postgres?pgbouncer=true"
# SHARD_1_DATABASE_URL="postgresql://user:pass@shard1.host:6543/postgres?pgbouncer=true"
# SHARD_2_DATABASE_URL="postgresql://user:pass@shard2.host:6543/postgres?pgbouncer=true"
# SHARD_3_DATABASE_URL="postgresql://user:pass@shard3.host:6543/postgres?pgbouncer=true"

# ==============================================================================
# AUDIT LOG IMMUTABILITY (Optional) — Forensic append-only audit sink
# ==============================================================================
# Streams every audit log event to Axiom, an append-only cloud log store.
# Axiom has no DELETE API in its ingest path — events can be queried but
# never mutated or deleted via the application-tier token. This gives you a
# forensic copy that survives even if the main Postgres database is compromised.
#
# Setup (5 minutes):
#   1. Create a free account at https://axiom.co
#   2. Create a dataset, e.g. "nexus-audit-logs"
#   3. Settings → API Tokens → New token → Ingest-Only scope on that dataset.
#      Important: do NOT grant Query or Management scope to this token.
#   4. Fill in the two vars below.
#   5. Run supabase-audit-immutability.sql in your Supabase SQL Editor to
#      install the DB-level BEFORE DELETE / BEFORE UPDATE trigger.
#
# Without these vars: audit logs are Postgres-only (still functional, but not
# forensically immutable). A warning is logged in production.
#
# To verify the Postgres guard is active (run in Supabase SQL Editor):
#   DELETE FROM audit_logs LIMIT 1;   -- should throw "NEXUS: audit_logs.DELETE is forbidden"
#   SELECT * FROM audit_logs LIMIT 5; -- should succeed normally
# ==============================================================================
# AXIOM_DATASET=nexus-audit-logs
# AXIOM_API_KEY=xaat_your_ingest_only_token_here

# ==============================================================================
# CRON SECRET - Shared secret for cron job and admin API routes
# Generate: openssl rand -base64 32
# ==============================================================================
CRON_SECRET=your_cron_secret_here

# ==============================================================================
# DEMO MODE - Optional: Set the org ID that runs in read-only demo mode
# ==============================================================================
# DEMO_ORG_ID=demo-org-id

# ==============================================================================
# AUTOMATION ENGINE - Optional: System user ID for automation-created events
# ==============================================================================
# SYSTEM_USER_ID=your_system_user_id_here

# ==============================================================================
# E2E TESTS (Playwright) - Only needed for running E2E tests
# ==============================================================================
# E2E_EMAIL=test@nexus-e2e.dev
# E2E_PASSWORD=TestPassword123!
